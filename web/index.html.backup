rativo de altera\u00e7\u00e3o de sobrenome\"         }       ],       \"raw_data\": null,       \"collected_at\": \"2026-03-18 16:59:38.367534\",       \"updated_at\": \"2026-03-18 16:59:38.367535\"     }   ] } ;

        function fmtDate(s){if(!s)return'-';return new Date(s).toLocaleDateString('pt-BR')}
        function fmtCurr(v){if(!v)return'-';return new Intl.NumberFormat('pt-BR',{style:'currency',currency:'BRL'}).format(v)}

        function renderStats(DATA){
            const companies = DATA.companies || [];
            const properties = DATA.properties || [];
            const processes = DATA.legal_processes || [];
            document.getElementById('statCompanies').textContent = companies.length;
            document.getElementById('statProperties').textContent = properties.length;
            document.getElementById('statProcesses').textContent = processes.length;
            const totalValue = (properties.reduce((a,p)=>a+(p.current_value||p.purchase_value||0),0)) + (companies.reduce((a,c)=>a+(c.capital||0),0));
            document.getElementById('statNetWorth').textContent = totalValue > 0 ? (totalValue/1e6).toFixed(1)+'M' : '-';
        }

        function renderPerson(DATA){
            const p = DATA.person;
            if(!p) return;
            const i = (p.full_name||'R').split(' ').map(n=>n[0]).join('').substring(0,2).toUpperCase();
            document.getElementById('profileCard').innerHTML = '<div class="profile-avatar">'+i+'</div><div class="profile-info"><h2>'+p.full_name+'</h2><div class="role">'+(p.profession||'Engenheiro Civil')+'</div><div class="details"><div class="detail-item"><span class="detail-label">CPF</span>'+(p.cpf||'-')+'</div><div class="detail-item"><span class="detail-label">RG</span>'+(p.rg?p.rg+(p.rg_uf?'-'+p.rg_uf:''):'-')+'</div><div class="detail-item"><span class="detail-label">CREA</span>'+(p.crea||'-')+'</div><div class="detail-item"><span class="detail-label">Nascimento</span>'+(p.birth_date?fmtDate(p.birth_date):'-')+'</div><div class="detail-item"><span class="detail-label">Cidade</span>'+(p.city||'Belo Horizonte')+'/'+(p.state||'MG')+'</div></div></div>';
        }

        function renderFamily(DATA){
            const sp = DATA.spouse, sib = DATA.siblings||[], nep = DATA.nephews||[];
            document.getElementById('familySpouseCount').textContent = sp ? 1 : 0;
            document.getElementById('familySiblingsCount').textContent = sib.length;
            document.getElementById('familyNephewsCount').textContent = nep.length;
            let h = '';
            if(sp) h += '<div class="family-card"><div class="family-avatar">'+sp.name.split(' ').map(n=>n[0]).join('').substring(0,2)+'</div><div class="family-name">'+sp.name+'</div><div class="family-relationship">Cônjuge</div><div class="family-details">'+(sp.profession?'<span>'+sp.profession+'</span>':'')+'</div></div>';
            sib.forEach(s=>h+='<div class="family-card"><div class="family-avatar">'+s.name.split(' ').map(n=>n[0]).join('').substring(0,2)+'</div><div class="family-name">'+s.name+'</div><div class="family-relationship">Irmão(ã)</div></div>');
            nep.forEach(n=>h+='<div class="family-card"><div class="family-avatar">'+n.name.split(' ').map(n=>n[0]).join('').substring(0,2)+'</div><div class="family-name">'+n.name+'</div><div class="family-relationship">'+(n.relationship==='niece'?'Sobrinha':'Sobrinho')+'</div><div class="family-details">'+(n.school?'<span>'+n.school+'</span>':'')+'</div></div>');
            document.getElementById('familyGrid').innerHTML = h;
        }

        function renderCompanies(DATA){
            const cs = DATA.companies||[];
            if(!cs.length) return document.getElementById('companiesGrid').innerHTML = '<div class="empty-state">Nenhuma empresa</div>';
            document.getElementById('companiesGrid').innerHTML = cs.map(c=>{const a=c.status?.toLowerCase()==='ativa';return'<div class="company-card"><div class="company-header"><div class="company-name">'+(c.trade_name||c.legal_name)+'</div><span class="company-status '+(a?'':'inactive')+'">'+(c.status||'Desconhecido')+'</span></div><div class="company-cnpj">'+(c.cnpj||'N/A')+'</div><div class="company-info">'+(c.activity?'<span>'+c.activity+'</span>':'')+'</div><div class="company-capital">Capital: <strong>'+fmtCurr(c.capital)+'</strong></div></div>'}).join('');
        }
        <script>
        function fmtDate(s){if(!s)return'-';return new Date(s).toLocaleDateString('pt-BR')}
        function fmtCurr(v){if(!v)return'-';return new Intl.NumberFormat('pt-BR',{style:'currency',currency:'BRL'}).format(v)}

        function renderAll(DATA) {

            function renderProperties(DATA){
                const ps = DATA.properties||[];
                if(!ps.length) return document.getElementById('propertiesGrid').innerHTML = '<div class="empty-state">Nenhum imóvel</div>';
                document.getElementById('propertiesGrid').innerHTML = ps.map(p=>{const q=p.status?.toLowerCase().includes('quit');return'<div class="property-card"><div class="property-header"><span class="property-type">'+(p.property_type||'Imóvel')+'</span><span class="property-status">'+(q?'✓ Quitado':(p.financing_value?'Financiado':'Desconhecido'))+'</span></div><div class="property-address">'+p.address+'</div><div class="property-neighborhood">'+(p.neighborhood||'')+' '+(p.city||'Belo Horizonte')+'/'+(p.state||'MG')+'</div><div class="property-stats"><div class="property-stat"><div class="property-stat-value">'+(p.area_sqm||'-')+'</div><div class="property-stat-label">m²</div></div><div class="property-stat"><div class="property-stat-value">'+(p.bedrooms||'-')+'</div><div class="property-stat-label">Quartos</div></div><div class="property-stat"><div class="property-stat-value">'+(p.parking_spaces||'-')+'</div><div class="property-stat-label">Vagas</div></div></div><div class="property-value">Matrícula: <strong>'+(p.registration||'N/A')+'</strong>'+(p.current_value?'<br>Valor: <strong>'+fmtCurr(p.current_value)+'</strong>':'')+'</div></div>'}).join('');
            }

            function renderContacts(DATA){
                const cs = DATA.contacts||[];
                if(!cs.length) return document.getElementById('contactsCard').innerHTML = '<div class="empty-state">Nenhum contato</div>';
                document.getElementById('contactsCard').innerHTML = cs.map(c=>'<div class="list-item"><div class="list-avatar">👤</div><div class="list-info"><div class="list-name">'+c.name+'</div><div class="list-meta">'+(c.role||'')+' '+(c.company?'• '+c.company:'')+'</div><div class="list-meta">'+(c.phone||'')+' '+(c.email?' • '+c.email:'')+'</div></div></div>').join('');
            }

            function renderDocuments(DATA){
                const ds = DATA.documents||[];
                if(!ds.length) return document.getElementById('documentsCard').innerHTML = '<div class="empty-state">Nenhum documento</div>';
                const i={rg:'🆔',cpf:'🪪',crea:'📜',birth_certificate:'📃'};
                document.getElementById('documentsCard').innerHTML = ds.map(d=>'<div class="list-item"><div class="list-avatar">'+(i[d.doc_type]||'📄')+'</div><div class="list-info"><div class="list-name">'+(d.title||d.doc_type)+'</div><div class="list-meta">'+(d.description||'')+'</div></div></div>').join('');
            }

            function renderLegal(DATA){
                const ps = DATA.legal_processes||[];
                if(!ps.length) return document.getElementById('legalGrid').innerHTML = '<div class="empty-state">Nenhum processo</div>';
                document.getElementById('legalGrid').innerHTML = ps.map(p=>{let filingsHtml='';if(p.filings&&p.filings.length){filingsHtml='<div class="legal-filings">'+p.filings.map(f=>'<div class="legal-filing">• '+(f.date||'')+' - '+(f.description||'')+'</div>').join('')+'</div>'}return'<div class="legal-card"><div class="legal-number">'+p.process_number+'</div><div class="legal-court">'+p.court+'</div><div class="legal-subject">'+(p.subject||'-')+'</div><div class="legal-parties">Partes: '+(p.parties?p.parties.join(', '):'-')+'</div><span class="legal-status">'+(p.status||'Em andamento')+'</span>'+filingsHtml+'</div>'}).join('');
            }
                nep.forEach(n=>h+='<div class="family-card"><div class="family-avatar">'+n.name.split(' ').map(n=>n[0]).join('').substring(0,2)+'</div><div class="family-name">'+n.name+'</div><div class="family-relationship">'+(n.relationship==='niece'?'Sobrinha':'Sobrinho')+'</div><div class="family-details">'+(n.school?'<span>'+n.school+'</span>':'')+'</div></div>');
                document.getElementById('familyGrid').innerHTML = h;
            }
            function renderCompanies(){
                const cs = DATA.companies||[];
                if(!cs.length) return document.getElementById('companiesGrid').innerHTML = '<div class="empty-state">Nenhuma empresa</div>';
                document.getElementById('companiesGrid').innerHTML = cs.map(c=>{const a=c.status?.toLowerCase()==='ativa';return'<div class="company-card"><div class="company-header"><div class="company-name">'+(c.trade_name||c.legal_name)+'</div><span class="company-status '+(a?'':'inactive')+'">'+(c.status||'Desconhecido')+'</span></div><div class="company-cnpj">'+(c.cnpj||'N/A')+'</div><div class="company-info">'+(c.activity?'<span>'+c.activity+'</span>':'')+'</div><div class="company-capital">Capital: <strong>'+fmtCurr(c.capital)+'</strong></div></div>'}).join('');
            }
            function renderProperties(){
                const ps = DATA.properties||[];
                if(!ps.length) return document.getElementById('propertiesGrid').innerHTML = '<div class="empty-state">Nenhum imóvel</div>';
                document.getElementById('propertiesGrid').innerHTML = ps.map(p=>{const q=p.status?.toLowerCase().includes('quit');return'<div class="property-card"><div class="property-header"><span class="property-type">'+(p.property_type||'Imóvel')+'</span><span class="property-status">'+(q?'✓ Quitado':(p.financing_value?'Financiado':'Desconhecido'))+'</span></div><div class="property-address">'+p.address+'</div><div class="property-neighborhood">'+(p.neighborhood||'')+' '+(p.city||'Belo Horizonte')+'/'+(p.state||'MG')+'</div><div class="property-stats"><div class="property-stat"><div class="property-stat-value">'+(p.area_sqm||'-')+'</div><div class="property-stat-label">m²</div></div><div class="property-stat"><div class="property-stat-value">'+(p.bedrooms||'-')+'</div><div class="property-stat-label">Quartos</div></div><div class="property-stat"><div class="property-stat-value">'+(p.parking_spaces||'-')+'</div><div class="property-stat-label">Vagas</div></div></div><div class="property-value">Matrícula: <strong>'+(p.registration||'N/A')+'</strong>'+(p.current_value?'<br>Valor: <strong>'+fmtCurr(p.current_value)+'</strong>':'')+'</div></div>'}).join('');
            }
            function renderContacts(){
                const cs = DATA.contacts||[];
                if(!cs.length) return document.getElementById('contactsCard').innerHTML = '<div class="empty-state">Nenhum contato</div>';
                document.getElementById('contactsCard').innerHTML = cs.map(c=>'<div class="list-item"><div class="list-avatar">👤</div><div class="list-info"><div class="list-name">'+c.name+'</div><div class="list-meta">'+(c.role||'')+' '+(c.company?'• '+c.company:'')+'</div><div class="list-meta">'+(c.phone||'')+' '+(c.email?' • '+c.email:'')+'</div></div></div>').join('');
            }
            function renderDocuments(){
                const ds = DATA.documents||[];
                if(!ds.length) return document.getElementById('documentsCard').innerHTML = '<div class="empty-state">Nenhum documento</div>';
                const i={rg:'🆔',cpf:'🪪',crea:'📜',birth_certificate:'📃'};
                document.getElementById('documentsCard').innerHTML = ds.map(d=>'<div class="list-item"><div class="list-avatar">'+(i[d.doc_type]||'📄')+'</div><div class="list-info"><div class="list-name">'+(d.title||d.doc_type)+'</div><div class="list-meta">'+(d.description||'')+'</div></div></div>').join('');
            }
            function renderLegal(){
                const ps = DATA.legal_processes||[];
                if(!ps.length) return document.getElementById('legalGrid').innerHTML = '<div class="empty-state">Nenhum processo</div>';
                document.getElementById('legalGrid').innerHTML = ps.map(p=>{let filingsHtml='';if(p.filings&&p.filings.length){filingsHtml='<div class="legal-filings">'+p.filings.map(f=>'<div class="legal-filing">• '+(f.date||'')+' - '+(f.description||'')+'</div>').join('')+'</div>'}return'<div class="legal-card"><div class="legal-number">'+p.process_number+'</div><div class="legal-court">'+p.court+'</div><div class="legal-subject">'+(p.subject||'-')+'</div><div class="legal-parties">Partes: '+(p.parties?p.parties.join(', '):'-')+'</div><span class="legal-status">'+(p.status||'Em andamento')+'</span>'+filingsHtml+'</div>'}).join('');
            }
            renderStats();renderPerson();renderFamily();renderCompanies();renderProperties();renderContacts();renderDocuments();renderLegal();
        }

        async function fetchAllData() {
            const [person, spouse, siblings, nephews, companies, properties, contacts, documents, legal_processes] = await Promise.all([
                fetch('/api/proxy/person').then(r=>r.json()),
                fetch('/api/proxy/spouse').then(r=>r.json()),
                fetch('/api/proxy/siblings').then(r=>r.json()),
                fetch('/api/proxy/nephews').then(r=>r.json()),
                fetch('/api/proxy/companies').then(r=>r.json()),
                fetch('/api/proxy/properties').then(r=>r.json()),
                fetch('/api/proxy/contacts').then(r=>r.json()),
                fetch('/api/proxy/documents').then(r=>r.json()),
                fetch('/api/proxy/legal/processes').then(r=>r.json()),
            ]);
            const DATA = {person, spouse, siblings, nephews, companies, properties, contacts, documents, legal_processes};
            renderStats(DATA);
            renderPerson(DATA);
            renderFamily(DATA);
            renderCompanies(DATA);
            renderProperties(DATA);
            renderContacts(DATA);
            renderDocuments(DATA);
            renderLegal(DATA);
        }

        fetchAllData();
        </script>

        // (Removed duplicate render functions and calls)
    </script>
</body>
</html>
